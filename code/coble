#!/bin/bash

# Detect install context (bin vs code dir)
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script_base="$(basename "$script_dir")"
if [[ "$script_base" == "bin" ]]; then
	install_context="conda"
else
	install_context="github"
fi
containers="conda"
# Optionally, you can use $install_context in help or logic
# Detect operating system
os_type="$(uname)"
echo "[coble] Detected OS: $os_type, Install context: $install_context" >&2

show_help() {
	echo "Usage: $0 <command> [options]"
	echo "  template   get a starter recipe of 5 given options"
	echo "  build    build (--rebuild) or update the conda enviroment from the recipe input"
	echo "  update   update an existing environment from the changes to the recipe input"	
	echo "  contain  Build Docker and Singularity containers from a COBLE recipe"
	echo "  freeze  capture the packages from an existing environment"
	echo "Example:"
	echo "  $0 template --recipe my.cbl --flavour basic"
	echo "  $0 build --recipe my.cbl --env my-env"
	echo "  $0 build --recipe my.cbl --env my-env --rebuild"
	echo "  $0 build --recipe my.cbl --env my-env --containers conda,docker,singularity"	
	echo "  $0 freeze --frozen my.cbl --env my-env"
}

start_time=$(date +%s)

echo '╔══════════════════════════════════════════════════════════════╗'
echo '║        COBLE Reproducible Environment v0.2                   ║'
echo '║        (c) ICR 2026 RSE and BCR-DS                           ║'
echo '║        For help, see:                                        ║'
echo '║        - https://icr-rse-group.github.io/coble/              ║'
echo '║        - https://github.com/ICR-RSE-Group/coble/issues       ║'
echo '╚══════════════════════════════════════════════════════════════╝'


echo "[coble] Starting coble at $(date)" >&2
copied_inputs=("$@")
container_type="conda"
for i in "${!copied_inputs[@]}"; do
	#echo "[coble] Checking arg: ${copied_inputs[$i]}" >&2
	if [[ "${copied_inputs[$i]}" == "--containers" ]]; then
		next_index=$((i + 1))
		if [[ $next_index -lt ${#copied_inputs[@]} ]]; then
			container_type="${copied_inputs[$next_index],,}"
		fi
		echo "[coble] Container build flag detected: $container_type"  >&2
		break
	fi		
done				
	
echo "[coble] Containers to build: $containers" >&2

# echo out all the inputs
echo "[coble] command entered: coble $*" >&2

# Global help option
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
	show_help
	exit 0
fi

# if the first command is not valid show help and exit
valid_commands=("template" "build" "update" "contain" "capture" "freeze")
if [[ ! " ${valid_commands[*]} " =~ " $1 " ]]; then
    echo "[coble] Not a valid command provided: $1." >&2
    show_help
    exit 1
fi

# If the first argument is 'template', call coble-template.sh and exit
if [[ "$1" == "template" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-template.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'build or update', call a succession of scripts checking status and exit
if [[ "$container_type" == *"conda"* ]]; then	
if [[ "$1" == "build" || "$1" == "update" ]]; then	
	# detect if there is a rebuild --rebuild flag in the args
	build_action="$1"
	if [[ " $* " == *" --rebuild "* ]]; then
		REBUILD_FLAG="--rebuild"
		# and remove it from the args
		set -- "${@/--rebuild/}"
		echo "[coble] Rebuild flag detected, will rebuild conda environment" >&2		
		build_action="build"
	else
		REBUILD_FLAG=""
		build_action="update"
	fi
	
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	# TODO SKIP THIS IF sh passed in as input
	echo "[coble 1/5] Resolving cbl..." >&2
	finds=$("$script_dir/coble-resolve.sh" "${@:2}")
	if [[ "$finds" == "Y" ]]; then
		echo "[coble] Finds were resolved, please check the yml input before resuming." >&2
		exit 1
	fi	
	
	echo "[coble 2/5] Resolved cbl, proceeding to rationalise." >&2
	success=$("$script_dir/coble-rationalise.sh" "${@:2}")	
	if [[ "$success" == "N" ]]; then
		echo "[coble] CBL rationalisation failed, please check the yml input before resuming." >&2
		exit 1
	fi
				
	echo "[coble 3/5] Rationalised cbl, proceeding to recipise." >&2	
	mapfile -t result < <("$script_dir/coble-recipise.sh" "${@:2}")
	success="${result[0]}"
	recipe_file="${result[1]}"
	if [[ "$success" == "N" ]]; then
		echo "[coble] Error in creating recipe, please correct input before resuming." >&2
		exit 1
	fi	
	
	base_name="${recipe_file##*/}"
    base_name_noext="${base_name%.*}"
    RESULTS_DIR="$(dirname "$recipe_file")"	    	
	done_recipe="$RESULTS_DIR/${base_name_noext}.done"
	summary_file="$RESULTS_DIR/${base_name_noext}_summary.txt"
	capture_file="$RESULTS_DIR/${base_name_noext}_freeze.cbl"
	
    
    if [[ "$REBUILD_FLAG" == "--rebuild" ]]; then
	    echo "[coble 3/5] Created recipe, rebuilding environment." >&2
	    : > "$done_recipe"
		: > "$summary_file"
	fi
				
	update_success=$("$script_dir/coble-update.sh" --done-recipe "$done_recipe" --all-recipe "$recipe_file")
	if [[ $? -ne 0 ]]; then		 
		echo "[coble] Error in updating recipe, please review logs before resuming." >&2
		exit 1
	fi		
	
	base_name="${recipe_file##*/}"
    base_name_noext="${base_name%.*}"
    RESULTS_DIR="$(dirname "$recipe_file")"	
    RECIPE_FILE="$RESULTS_DIR/${base_name_noext}.delta"    

	echo "[coble 4/5] Created recipe, proceeding to creation from $RECIPE_FILE" >&2	
		
	result=$("$script_dir/coble-create.sh" --recipe-bash "$RECIPE_FILE" "${@:2}")
				
	if [[ $? -ne 0 ]]; then		 
		echo "[coble] Error in environment creation, please review logs before resuming." >&2

		end_time=$(date +%s)
	    duration=$((end_time - start_time))
	    hours=$((duration / 3600))
	    minutes=$(((duration % 3600) / 60))
	    seconds=$((duration % 60))
	    echo "[coble] Time taken to get here $(date) (Duration: ${hours}h ${minutes}m ${seconds}s)" >&2	
		exit 1
	fi
	
	echo "[coble 5/5] Created env, proceeding to freeze in file $capture_file" >&2	
    # replace --recipe existring with capture file    
	#recipe_dir="$(dirname "$recipe_file")"	
	result=$("$script_dir/coble-capture.sh" --frozen "$capture_file" "${@:2}")
		
	echo "[coble] Environment creation complete." >&2
	end_time=$(date +%s)
	duration=$((end_time - start_time))
	hours=$((duration / 3600))
	minutes=$(((duration % 3600) / 60))
	seconds=$((duration % 60))
	echo "[coble] Completed coble at $(date) (Duration: ${hours}h ${minutes}m ${seconds}s)" >&2		
fi
fi

# If the first argument is 'contain', or 'build' with docker/singularity containers
if [[ "$1" == "contain" ]] || [[ "$1" == "build" && ( "$container_type" == *"docker"* || "$container_type" == *"singularity"* ) ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-container.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'capture', call coble-capture.sh and exit
if [[ "$1" == "capture" || "$1" == "freeze" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-capture.sh" "${@:2}"
	exit $?
fi
end_time=$(date +%s)
duration=$((end_time - start_time))
hours=$((duration / 3600))
minutes=$(((duration % 3600) / 60))
seconds=$((duration % 60))
echo "[coble] Completed coble at $(date) (Duration: ${hours}h ${minutes}m ${seconds}s)" >&2
