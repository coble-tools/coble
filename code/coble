#!/bin/bash

# Detect install context (bin vs code dir)
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script_base="$(basename "$script_dir")"
if [[ "$script_base" == "bin" ]]; then
	install_context="conda"
else
	install_context="github"
fi
# Optionally, you can use $install_context in help or logic

show_help() {
	echo "Usage: $0 <command> [options]"
	echo "  capture   Capture the current environment (calls coble-capture.sh)"
	echo "  recreate/create  Recreate an environment from a capture (calls coble-recreate.sh)"
	echo "Example:"
	echo "  $0 capture [options]"
	echo "  $0 recreate/create [options]"
}

# Global help option
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
	show_help
	exit 0
fi

# If the first argument is 'template', call coble-template.sh and exit
if [[ "$1" == "template" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-template.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'capture', call coble-capture.sh and exit
if [[ "$1" == "capture" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-capture.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'create', call a succession of scripts checking status and exit
if [[ "$1" == "create" ]]; then	
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	# TODO SKIP THIS IF sh passed in as input
	echo "[coble-create 1/4] Resolving yml..." >&2
	finds=$("$script_dir/coble-resolve.sh" "${@:2}")
	if [[ "$finds" == "Y" ]]; then
		echo "[coble-create] Finds were resolved, please check the yml input before resuming." >&2
		exit 0
	fi	
	
	echo "[coble-create 2/4] Resolved yml, proceeding to rationalise." >&2
	success=$("$script_dir/coble-rationalise.sh" "${@:2}")
				
	echo "[coble-create 2/4] Rationalised yml, proceeding to recipise." >&2	
	mapfile -t result < <("$script_dir/coble-recipise.sh" "${@:2}")
	success="${result[0]}"
	recipe_file="${result[1]}"
	if [[ "$success" == "N" ]]; then
		echo "[coble-build] Error in creating recipe, please correct input before resuming." >&2
		exit 0
	fi	
	
	echo "[coble-create 3/4] Created recipe, proceeding to creation." >&2
	result=$("$script_dir/coble-create.sh" --recipe "$recipe_file" "${@:2}")
	
	echo "[coble-create 4/4] Created env, proceeding to capture." >&2
	#"$script_dir/coble-capture.sh" "${@:2}"
	
	echo "[coble-create] Environment creation complete." >&2
	exit $?
fi

# If the first argument is 'recreate', call coble-recreate.sh and exit
if [[ "$1" == "recreate" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-recreate.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'recipise', call coble-recipise.sh and exit
if [[ "$1" == "recipise" || "$1" == "recipe" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-recipise.sh" "${@:2}"
	exit $?
fi

# If the first argument is 'resolve' or find, call coble-resolve.sh and exit
if [[ "$1" == "resolve" || "$1" == "find" ]]; then
	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	"$script_dir/coble-resolve.sh" "${@:2}"	
	exit $?
fi

# output a requirements.txt file
echo "Not a valid command provided: $1."
show_help