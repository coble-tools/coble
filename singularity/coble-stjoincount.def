Bootstrap: docker
From: continuumio/miniconda3

%labels
    org.opencontainers.image.version stjoincount
    org.opencontainers.image.title coble-stjoincount
    org.opencontainers.image.description COBLE stjoincount variant - join count analysis bioinformatics environment
    org.opencontainers.image.source https://github.com/ICR-RSE-Group/coble
    org.opencontainers.image.licenses MIT

%files
    bin /app/bin
    config /app/config

%environment
    export PATH=/app/envs/coble/bin:$PATH
    export RESULTS_DIR=/app/results/coble-stjoincount
    export ENVS_DIR=/app/envs/coble
    export PKGS_DIR=/app/pkgs/coble
    export CONFIG_FILE=/app/config/coble-stjoincount.yml
    export COBLE_VARIANT=stjoincount
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    export MAMBA_NO_BANNER=1
    export SINGULARITY_SHELL=/app/activate_env.sh
    export R_LIBS_USER=~/R/coble-stjoincount-library
    export R_LIBS=~/R/coble-stjoincount-library:/app/envs/coble/lib/R/library

%post
    cd /app
    
    # Set variant name (change this line to adapt for other variants)
    VARIANT="stjoincount"
    SOLVER="conda"
    
    echo "========================================"
    echo "Building COBLE variant: ${VARIANT}"
    echo "Config: /app/config/coble-${VARIANT}.yml"
    echo "Solver: ${SOLVER}"
    echo "========================================"

    # Create directories and .condarc FIRST before any conda operations
    mkdir -p results logs pkgs envs
    cat > /root/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
channel_priority: strict
show_channel_urls: true
EOF
    
    # Also create for /app
    cat > /app/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
channel_priority: strict
show_channel_urls: true
default_channels:
  - https://conda.anaconda.org/conda-forge
custom_multichannels:
  defaults: []
EOF
    export CONDARC=/root/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble

    # Ensure latest conda from conda-forge and update base packages
    echo "Updating conda and base packages from conda-forge..."    
    conda install -y -n base conda && \
    conda update -y -n base --all && \
    conda clean -afy

    # Install system dependencies
    apt-get update && \
        apt-get install -y --no-install-recommends \
            build-essential \
            zlib1g-dev \
            libgomp1 && \
        rm -rf /var/lib/apt/lists/*

    # Build the environment
    
    echo "Running coble-bash.sh with ${SOLVER}..."
    bash /app/bin/coble-bash.sh \
        --steps "${SOLVER}:create,export,errors,missing" \
        --input "/app/config/coble-${VARIANT}.yml" \
        --results "/app/results/coble-${VARIANT}" \
        --r-version "4.5.2" \
        --python-version "3.14.0" \
        --env "/app/envs/coble" \
        --pkg "/app/pkgs/coble" \
        --quiet "n" \
        --divert "y"

    # Verify environment was created
    echo "=== Verifying environment ==="
    ls -la /app/envs/
    conda env list
    ls -la /app/envs/coble/ || echo "Directory not found"

    # Create singularity-friendly activation scripts
    cat > /app/activate_env.sh <<'EOF'
#!/bin/bash
# Try multiple methods to initialize conda
if [ -n "${CONDA_EXE}" ] && [ -f "${CONDA_EXE%/bin/conda}/etc/profile.d/conda.sh" ]; then
    source "${CONDA_EXE%/bin/conda}/etc/profile.d/conda.sh"
elif [ -f /opt/conda/etc/profile.d/conda.sh ]; then
    source /opt/conda/etc/profile.d/conda.sh
else
    eval "$(${CONDA_EXE:-conda} shell.bash hook)" 2>/dev/null || true
fi

# Activate with fallback to PATH
conda activate /app/envs/coble 2>/dev/null || true
export PATH=/app/envs/coble/bin:$PATH
export R_LIBS_USER=~/R/coble-stjoincount-library
export R_LIBS=~/R/coble-stjoincount-library:/app/envs/coble/lib/R/library
mkdir -p "$R_LIBS_USER"
exec bash
EOF
    chmod +x /app/activate_env.sh

    cat > /app/activate_conda.sh <<'EOF'
#!/bin/bash
# Try multiple methods to initialize conda
if [ -n "${CONDA_EXE}" ] && [ -f "${CONDA_EXE%/bin/conda}/etc/profile.d/conda.sh" ]; then
    source "${CONDA_EXE%/bin/conda}/etc/profile.d/conda.sh"
elif [ -f /opt/conda/etc/profile.d/conda.sh ]; then
    source /opt/conda/etc/profile.d/conda.sh
else
    eval "$(${CONDA_EXE:-conda} shell.bash hook)" 2>/dev/null || true
fi

# Activate with fallback to PATH
conda activate /app/envs/coble 2>/dev/null || true
export PATH=/app/envs/coble/bin:$PATH
export R_LIBS_USER=~/R/coble-stjoincount-library
export R_LIBS=~/R/coble-stjoincount-library:/app/envs/coble/lib/R/library
mkdir -p "$R_LIBS_USER"
EOF
    chmod +x /app/activate_conda.sh

    cat > /app/use_env.sh <<'EOF'
#!/bin/bash
# Simple PATH-based setup without conda activation
export PATH=/app/envs/coble/bin:$PATH
export R_LIBS_USER=~/R/coble-stjoincount-library
export R_LIBS=~/R/coble-stjoincount-library:/app/envs/coble/lib/R/library
mkdir -p "$R_LIBS_USER"
EOF
    chmod +x /app/use_env.sh

    # Clean conda cache
    conda clean -afy

%runscript
    exec /bin/bash "$@"

%startscript
    source /opt/conda/etc/profile.d/conda.sh
    conda activate /app/envs/coble
    exec /bin/bash

%help
    COBLE - stjoincount variant
    
    Join count analysis focused bioinformatics conda environment.
    
    Usage:
        # Interactive shell (auto-activates environment)
        singularity shell coble-stjoincount.sif
        
        # Direct execution (recommended - works without conda activation)
        singularity exec coble-stjoincount.sif python script.py
        singularity exec coble-stjoincount.sif Rscript analysis.R
        
        # With explicit conda activation (if needed)
        singularity exec coble-stjoincount.sif bash -c "source /app/activate_conda.sh && python script.py"
        
        # Simple PATH-based setup (no conda activation)
        singularity exec coble-stjoincount.sif bash -c "source /app/use_env.sh && python script.py"
    
    Build:
        sudo singularity build coble-stjoincount.sif singularity/coble-stjoincount.def
    
    More info: https://github.com/ICR-RSE-Group/coble
