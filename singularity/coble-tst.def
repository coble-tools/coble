Bootstrap: docker
From: continuumio/miniconda3

%labels
    org.opencontainers.image.version tst
    org.opencontainers.image.title coble-tst
    org.opencontainers.image.description COBLE tst variant - experimental/test bioinformatics environment
    org.opencontainers.image.source https://github.com/ICR-RSE-Group/coble
    org.opencontainers.image.licenses MIT

%files
    bin /app/bin
    config /app/config

%environment
    export RESULTS_DIR=/app/results/coble-tst
    export ENVS_DIR=/app/envs/coble
    export PKGS_DIR=/app/pkgs/coble
    export CONFIG_FILE=/app/config/coble-tst.yml
    export COBLE_VARIANT=tst
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    export MAMBA_NO_BANNER=1
    export SINGULARITY_SHELL=/app/activate_env.sh
    export R_LIBS_USER=~/R/coble-tst-library
    export R_LIBS=~/R/coble-tst-library:/app/envs/coble/lib/R/library
    # Add conda environment to PATH automatically
    export PATH=/app/envs/coble/bin:$PATH

%post
    cd /app
    
    # Set variant name (change this line to adapt for other variants)
    VARIANT="tst"
    SOLVER="conda"
    
    echo "========================================"
    echo "Building COBLE variant: ${VARIANT}"
    echo "Config: /app/config/coble-${VARIANT}.yml"
    echo "Solver: ${SOLVER}"
    echo "========================================"

    # Create directories and .condarc FIRST before any conda operations
    mkdir -p results logs pkgs envs
    cat > /root/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
channel_priority: strict
show_channel_urls: true
EOF
    
    # Also create for /app
    cat > /app/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
channel_priority: strict
show_channel_urls: true
default_channels:
  - https://conda.anaconda.org/conda-forge
custom_multichannels:
  defaults: []
EOF
    export CONDARC=/root/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble

    # Ensure latest conda from conda-forge and update base packages
    echo "Updating conda and base packages from conda-forge..."    
    conda install -y -n base conda && \
    conda update -y -n base --all && \
    conda clean -afy

    # Install system dependencies
    apt-get update && \
        apt-get install -y --no-install-recommends \
            build-essential \
            zlib1g-dev \
            libgomp1 && \
        rm -rf /var/lib/apt/lists/*

    # Build the environment
    
    echo "Running coble-bash.sh with ${SOLVER}..."
    bash /app/bin/coble-bash.sh \
        --steps "${SOLVER}:create,export,errors,missing" \
        --input "/app/config/coble-${VARIANT}.yml" \
        --results "/app/results/coble-${VARIANT}" \
        --r-version "4.5.2" \
        --python-version "3.14.0" \
        --env "/app/envs/coble" \
        --pkg "/app/pkgs/coble" \
        --quiet "n" \
        --divert "y"

    # Verify environment was created
    echo "=== Verifying environment ==="
    ls -la /app/envs/
    conda env list
    ls -la /app/envs/coble/ || echo "Directory not found"

    # Create singularity-friendly activation scripts
    cat > /app/activate_env.sh <<'EOF'
#!/bin/bash
# Initialize conda in multiple ways for maximum compatibility
if [ -f /opt/conda/etc/profile.d/conda.sh ]; then
    . /opt/conda/etc/profile.d/conda.sh
elif [ -f "$CONDA_EXE" ]; then
    eval "$($CONDA_EXE shell.bash hook)"
fi
conda activate /app/envs/coble 2>/dev/null || true
export R_LIBS_USER=~/R/coble-tst-library
export R_LIBS=~/R/coble-tst-library:/app/envs/coble/lib/R/library
export PATH=/app/envs/coble/bin:$PATH
mkdir -p "$R_LIBS_USER"
exec bash
EOF
    chmod +x /app/activate_env.sh

    cat > /app/activate_conda.sh <<'EOF'
#!/bin/bash
# Initialize conda in multiple ways for maximum compatibility
if [ -f /opt/conda/etc/profile.d/conda.sh ]; then
    . /opt/conda/etc/profile.d/conda.sh
elif [ -f "$CONDA_EXE" ]; then
    eval "$($CONDA_EXE shell.bash hook)"
fi
conda activate /app/envs/coble 2>/dev/null || true
export R_LIBS_USER=~/R/coble-tst-library
export R_LIBS=~/R/coble-tst-library:/app/envs/coble/lib/R/library
export PATH=/app/envs/coble/bin:$PATH
mkdir -p "$R_LIBS_USER"
EOF
    chmod +x /app/activate_conda.sh
    
    # Create a simpler path-based wrapper for users who don't want conda activation
    cat > /app/use_env.sh <<'EOF'
#!/bin/bash
# Simple PATH-based activation (no conda needed)
export PATH=/app/envs/coble/bin:$PATH
export R_LIBS_USER=~/R/coble-tst-library
export R_LIBS=~/R/coble-tst-library:/app/envs/coble/lib/R/library
mkdir -p "$R_LIBS_USER"
EOF
    chmod +x /app/use_env.sh

    # Clean conda cache
    conda clean -afy

%runscript
    exec /bin/bash "$@"

%startscript
    source /opt/conda/etc/profile.d/conda.sh
    conda activate /app/envs/coble
    exec /bin/bash

%help
    COBLE - tst variant
    
    Experimental/test bioinformatics conda environment.
    
    Usage Options:
    
    1. Interactive shell (auto-activates via SINGULARITY_SHELL):
        singularity shell coble-tst.sif
    
    2. Run commands directly (PATH-based, no conda activation needed):
        singularity exec coble-tst.sif python script.py
        singularity exec coble-tst.sif R -e "library(tidyverse)"
    
    3. Explicit conda activation (if you need conda-specific features):
        singularity exec coble-tst.sif bash -c "source /app/activate_conda.sh && python script.py"
    
    4. Simple PATH-based setup (alternative to conda activation):
        singularity exec coble-tst.sif bash -c "source /app/use_env.sh && python script.py"
    
    Environment Details:
        - Python and R executables are in PATH by default
        - R libraries: ~/R/coble-tst-library and /app/envs/coble/lib/R/library
        - Config: /app/config/coble-tst.yml
    
    Build:
        sudo singularity build coble-tst.sif singularity/coble-tst.def
    
    More info: https://github.com/ICR-RSE-Group/coble
