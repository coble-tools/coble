Bootstrap: docker
From: continuumio/miniconda3

%labels
    org.opencontainers.image.version 452
    org.opencontainers.image.title coble-452
    org.opencontainers.image.description COBLE 452 variant - full bioinformatics environment
    org.opencontainers.image.source https://github.com/ICR-RSE-Group/coble
    org.opencontainers.image.licenses MIT

%files
    bin /app/bin
    config /app/config

%environment
    export RESULTS_DIR=/app/results/coble-452
    export ENVS_DIR=/app/envs/coble
    export PKGS_DIR=/app/pkgs/coble
    export CONFIG_FILE=/app/config/coble-452.yml
    export COBLE_VARIANT=452
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    export MAMBA_NO_BANNER=1
    export SINGULARITY_SHELL=/app/activate_env.sh
    export R_LIBS_USER=~/R/coble-452-library
    export R_LIBS=~/R/coble-452-library:/app/envs/coble/lib/R/library

%post
    cd /app
    
    echo "========================================"
    echo "Building COBLE variant: 452"
    echo "Config: /app/config/coble-452.yml"
    echo "Solver: mamba (faster)"
    echo "========================================"

    # Prepare directories and .condarc (exclude defaults)
    mkdir -p results logs pkgs envs
        cat > /app/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
  - nodefaults
channel_priority: strict
default_channels:
    - https://conda.anaconda.org/conda-forge
custom_multichannels:
    defaults: []
EOF
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble

    # Install system dependencies
    apt-get update && \
        apt-get install -y --no-install-recommends \
            build-essential \
            zlib1g-dev \
            libgomp1 && \
        rm -rf /var/lib/apt/lists/*

    # Ensure latest conda and mamba from conda-forge, then update base
    echo "Installing conda and mamba from conda-forge, updating base..."
    conda install -y -n base -c conda-forge conda mamba && \
    conda update -y -n base --all && \
    conda clean -afy

    # Build the environment
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    
    echo "Running coble-bash.sh with mamba..."
    bash /app/bin/coble-bash.sh \
        --steps "mamba:create,export,errors,missing" \
        --input "/app/config/coble-452.yml" \
        --results "/app/results/coble-452" \
        --r-version "4.5.2" \
        --python-version "3.14.0" \
        --env "/app/envs/coble" \
        --pkg "/app/pkgs/coble" \
        --quiet "y" \
        --divert "y"

    # Verify environment was created
    echo "=== Verifying environment ==="
    ls -la /app/envs/
    conda env list
    ls -la /app/envs/coble/ || echo "Directory not found"

    # Create singularity-friendly activation scripts
    cat > /app/activate_env.sh <<'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate /app/envs/coble
exec bash
EOF
    chmod +x /app/activate_env.sh

    cat > /app/activate_conda.sh <<'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate /app/envs/coble
EOF
    chmod +x /app/activate_conda.sh

    # Clean conda cache
    conda clean -afy

%runscript
    exec /bin/bash "$@"

%startscript
    source /opt/conda/etc/profile.d/conda.sh
    conda activate /app/envs/coble
    exec /bin/bash

%help
    COBLE - 452 variant
    
    Full bioinformatics conda environment with 452+ packages.
    
    Usage:
        # Interactive shell (auto-activates environment)
        singularity shell coble-452.sif
        
        # Execute command with activated environment
        singularity exec coble-452.sif bash -c "source /app/activate_conda.sh && python script.py"
    
    Build:
        sudo singularity build coble-452.sif singularity/coble-452.def
    
    More info: https://github.com/ICR-RSE-Group/coble
