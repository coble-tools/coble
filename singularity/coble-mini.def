Bootstrap: docker
From: continuumio/miniconda3

%labels
    org.opencontainers.image.version mini
    org.opencontainers.image.title coble-mini
    org.opencontainers.image.description COBLE mini variant - minimal bioinformatics environment
    org.opencontainers.image.source https://github.com/ICR-RSE-Group/coble
    org.opencontainers.image.licenses MIT

%files
    bin /app/bin
    config /app/config

%environment
    export RESULTS_DIR=/app/results/coble-mini
    export ENVS_DIR=/app/envs/coble
    export PKGS_DIR=/app/pkgs/coble
    export CONFIG_FILE=/app/config/coble-mini.yml
    export COBLE_VARIANT=mini
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    export MAMBA_NO_BANNER=1
    export SINGULARITY_SHELL=/app/activate_env.sh
    export R_LIBS_USER=~/R/coble-mini-library

%post
    cd /app
    
    echo "========================================"
    echo "Building COBLE variant: mini"
    echo "Config: /app/config/coble-mini.yml"
    echo "Solver: conda"
    echo "========================================"

    # Update conda and all base packages to latest (removes upgrade prompt)
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r
    conda update -n base -c defaults conda -y && \
    conda update -n base -c defaults --all -y && \
    conda clean -afy

    # Install system dependencies
    apt-get update && \
        apt-get install -y --no-install-recommends \
            build-essential \
            zlib1g-dev \
            libgomp1 && \
        rm -rf /var/lib/apt/lists/*

    # Refresh conda from conda-forge after base update
    echo "Ensuring latest conda from conda-forge..."
    conda install -y -n base -c conda-forge conda && conda clean -afy
    
    # Create directories
    mkdir -p results logs pkgs envs

    # Create .condarc with channels (explicitly exclude defaults repo)
    cat > /app/.condarc <<EOF
channels:
  - conda-forge
  - bioconda
  - https://conda.anaconda.org/dranew
  - nodefaults
channel_priority: strict
EOF

    # Build the environment
    export CONDARC=/app/.condarc
    export CONDA_PKGS_DIRS=/app/pkgs/coble
    
    echo "Running coble-bash.sh..."
    bash /app/bin/coble-bash.sh \
        --steps "conda:create,export,errors,missing" \
        --input "/app/config/coble-mini.yml" \
        --results "/app/results/coble-mini" \
        --r-version "4.5.2" \
        --python-version "3.14.0" \
        --env "/app/envs/coble" \
        --pkg "/app/pkgs/coble" \
        --quiet "y" \
        --divert "y"

    # Verify environment was created
    echo "=== Verifying environment ==="
    ls -la /app/envs/
    conda env list
    ls -la /app/envs/coble/ || echo "Directory not found"

    # Create singularity-friendly activation scripts
    cat > /app/activate_env.sh <<'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate /app/envs/coble
exec bash
EOF
    chmod +x /app/activate_env.sh

    cat > /app/activate_conda.sh <<'EOF'
#!/bin/bash
source /opt/conda/etc/profile.d/conda.sh
conda activate /app/envs/coble
EOF
    chmod +x /app/activate_conda.sh

    # Clean conda cache
    conda clean -afy

%runscript
    exec /bin/bash "$@"

%startscript
    source /opt/conda/etc/profile.d/conda.sh
    conda activate /app/envs/coble
    exec /bin/bash

%help
    COBLE - mini variant
    
    Minimal bioinformatics conda environment.
    
    Usage:
        # Interactive shell (auto-activates environment)
        singularity shell coble-mini.sif
        
        # Execute command with activated environment
        singularity exec coble-mini.sif bash -c "source /app/activate_conda.sh && python script.py"
    
    Build:
        sudo singularity build coble-mini.sif singularity/coble-mini.def
    
    More info: https://github.com/ICR-RSE-Group/coble
